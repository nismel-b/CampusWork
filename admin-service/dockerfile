# ==============================================
# ENVIRONMENT VARIABLES
# File: .env.example
# ==============================================

# SERVICE CONFIGURATION
NODE_ENV=development
PORT=3004
SERVICE_NAME=admin-service

# DATABASE CONFIGURATION
DB_HOST=admin-db
DB_PORT=5432
DB_NAME=admin_db
DB_USER=postgres
DB_PASSWORD=postgres

# REDIS CONFIGURATION (optional for admin service)
REDIS_HOST=redis
REDIS_PORT=6379

# RABBITMQ CONFIGURATION (optional for admin service)
RABBITMQ_URL=amqp://admin:admin@rabbitmq:5672

# SERVICE-TO-SERVICE COMMUNICATION
AUTH_SERVICE_URL=http://auth-service:3001
STUDENT_SERVICE_URL=http://student-service:3002
LECTURER_SERVICE_URL=http://lecturer-service:3003

# JWT Secret (must match Auth Service)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Service-to-service authentication token
SERVICE_AUTH_TOKEN=shared-secret-token-between-services

# CORS CONFIGURATION
CORS_ORIGIN=*

# LOGGING
LOG_LEVEL=info
